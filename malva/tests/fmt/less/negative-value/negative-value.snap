---
source: malva/tests/fmt.rs
---
@card-spacing: 15px;

.cards {
  margin: 0 -@card-spacing;
}

.variable {
  margin: 2 -@card-spacing;
}

.variable-binary-spaced {
  margin: 2 - @card-spacing;
}

.variable-binary-tight {
  margin: 2 - @card-spacing;
}

.parens {
  margin: 2 -(@card-spacing);
}

.parens-binary-spaced {
  margin: 2 - (@card-spacing);
}
